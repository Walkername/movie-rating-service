# Stage 1: build React app
FROM node:20-alpine AS build
WORKDIR /app

ARG REACT_APP_USER_SERVICE_URL
ARG REACT_APP_MOVIE_SERVICE_URL
ARG REACT_APP_RATING_SERVICE_URL
ARG REACT_APP_FILE_SERVICE_URL
ARG REACT_APP_USER_LIBRARY_URL
ARG REACT_APP_FEED_SERVICE_URL
ARG REACT_APP_NOTIFICATION_SERVICE_URL
ARG REACT_APP_CONVERSATION_SERVICE_URL
ARG REACT_APP_NOTIFICATION_WEBSOCKET_URL
ARG REACT_APP_CONVERSATION_WEBSOCKET_URL

ENV REACT_APP_USER_SERVICE_URL=$REACT_APP_USER_SERVICE_URL
ENV REACT_APP_MOVIE_SERVICE_URL=$REACT_APP_MOVIE_SERVICE_URL
ENV REACT_APP_RATING_SERVICE_URL=$REACT_APP_RATING_SERVICE_URL
ENV REACT_APP_FILE_SERVICE_URL=$REACT_APP_FILE_SERVICE_URL
ENV REACT_APP_USER_LIBRARY_URL=$REACT_APP_USER_LIBRARY_URL
ENV REACT_APP_FEED_SERVICE_URL=$REACT_APP_FEED_SERVICE_URL
ENV REACT_APP_NOTIFICATION_SERVICE_URL=$REACT_APP_NOTIFICATION_SERVICE_URL
ENV REACT_APP_CONVERSATION_SERVICE_URL=$REACT_APP_CONVERSATION_SERVICE_URL
ENV REACT_APP_NOTIFICATION_WEBSOCKET_URL=$REACT_APP_NOTIFICATION_WEBSOCKET_URL
ENV REACT_APP_CONVERSATION_WEBSOCKET_URL=$REACT_APP_CONVERSATION_WEBSOCKET_URL

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: serve with nginx
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
